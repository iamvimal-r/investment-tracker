# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Expo ──────────────────────────────────────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts

# ── Native builds ─────────────────────────────────────────────────────────────
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
/ios
/android

# ── Metro bundler ─────────────────────────────────────────────────────────────
.metro-health-check*

# ── Debug logs ────────────────────────────────────────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── EAS / Build artifacts ─────────────────────────────────────────────────────
.easignore
eas-build-local-*/

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/

# ── Misc ──────────────────────────────────────────────────────────────────────
app-example
*.log
